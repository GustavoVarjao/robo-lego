/* Este cï¿½digo funciona de maneira que o robï¿½ possa se movimentar atravï¿½s dos motores A e C
Gire no prï¿½prio eixo para a esquerda com 50% da potï¿½ncia atï¿½ que identifique um adversï¿½rio a menos de 35cm.
Uma vez identificado, o robï¿½ andarï¿½ para frente em velocidade mï¿½xima atï¿½ que a luta acabe ou ele perca o adversï¿½rio de vista.

O intuito do desafio ï¿½ adaptar o cï¿½digo ao robï¿½ de vocï¿½s, adicionar movimentaï¿½ï¿½o inicial na funï¿½ï¿½o prï¿½ definida e realizar ajustes
na velocidade dos motores conforme forem necessï¿½rios

Os comandos bï¿½sicos sï¿½o:

OnFwd(MOTOR, POTENCIA (0 a 100));
delay(milisegundos);

Laï¿½os sï¿½o os comuns de C, while, for, do while, until.

Condicionais if, else if, else, switch case.

Para outras funï¿½ï¿½es, tasks, structures ou condicionamentos especiais, procurar ajuda na staff do estï¿½gio */

//==============================================================================
//==============================================================================
//==============================================================================

/* Ordem de montagem:

Motor da Direita na porta A
Motor da Arma ou desarme na porta B
Motor da Esquerda na porta C
Sensor na porta 1
Qualquer outra condiï¿½ï¿½o ou ideia, buscar apoio dos membros da equipe para configuraï¿½ï¿½o
*/

//==============================================================================
//==============================================================================
//==============================================================================

//__________Nï¿½O MEXER SEM APOIO DA STAFF_______________________________________
#define motorDireita OUT_A      // Motor Direito --> entrada A
#define motorArma OUT_B         // Possï¿½vel motor de Arma --> entrada B
#define motorEsquerda OUT_C     // Motor Esquerdo --> entrada C
#define distancia_sensorE SensorUS(IN_1)// Sensor Ultrassï¿½nico --> entrada 1
#define distancia_sensorD SensorUS(IN_2)// Sensor Ultrassï¿½nico --> entrada 2
task manterArmaParada();




//__________MEXER PARA REGULAR A DISTANCIA DE BUSCA E ATAQUE____________________
#define distancia_busca 35      // Limiar para o robï¿½ comeï¿½ar a andar para frente, em centï¿½metros
#define distancia_ataque 5

//__________MEXER PARA REGULAR O SENTIDO DOS MOTORES____________________________
#define sr 1                    // sr: Sentido das rodas - se o sentido das rodas estiverem invertidos mudar para -1
#define sa 1                    // sa: Sentido da arma - se o sentido da arma estiver invertido mudar para -1

//__________VARIï¿½VEIS DE CONTROLE_______________________________________________
int armaEstaAtiva = false;
int ultimaPosicao = 1;

//==============================================================================
//=========================CORPO DO Cï¿½DIGO======================================
//==============================================================================

task main(){

    SetSensorLowspeed(IN_1);            // Nï¿½O MEXER SUJEITO ï¿½ >>>PROBLEMAS<<<
    SetSensorLowspeed(IN_2);
    Wait(5000);                         // Tempo de espera previsto nas regras

    StartTask(manterArmaParada);
    Wait(1000); // Espera a arma abaixar


    while(true) {

      if((distancia_sensorD <= distancia_busca) && (distancia_sensorE <= distancia_busca)) { // Verifica se o oponente estï¿½ na frente
         OnFwd(motorEsquerda, 100*sr); // Avanï¿½a com velocidade mï¿½xima para frente ao localizar o oponente
         OnFwd(motorDireita, 100*sr);
      } else if (distancia_sensorD <= distancia_busca) {
         OnFwd(motorEsquerda, 75*sr); // Se achar o oponente no sensor direito, faz uma curva no sentido horï¿½rio
         OnFwd(motorDireita, 10*sr);
         ultimaPosicao = 1;
      } else if (distancia_sensorE <= distancia_busca) {
         OnFwd(motorEsquerda, 10*sr); // Se achar o oponente no sensor esquerdo, faz uma curva no sentido anti horï¿½rio
         OnFwd(motorDireita, 75*sr);
         ultimaPosicao = -1;
      } else {
         OnFwd(motorEsquerda, 75*sr*ultimaPosicao); // Se nï¿½o achar o oponente, gira sentido da ï¿½ltima detecï¿½ï¿½o
         OnFwd(motorDireita, -75*sr*ultimaPosicao);
      }

      Wait(20);
    }
}

task manterArmaParada() {
     ResetRotationCount(motorArma);

    int alvo = -30; // Ver qual altura ideal da arma
    int margemDeErro = 5;

    RotateMotor(motorArma, 20*sa, alvo); // Desce a arma inciialmente

    while(true) {
        int posicao = MotorRotationCount(motorArma);


        if (posicao < (alvo - margemDeErro)) {  // Compara a posiï¿½ï¿½o da arma com o alvo e faz  ajuste
            OnFwd(motorArma, 20*sa);
        } else if (posicao > (alvo + margemDeErro)) {
            OnFwd(motorArma, -20*sa);
        } else {
          Off(motorArma);
        }

        Wait(20);
    }
}
